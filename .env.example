# 텔레그램 설정
TELEGRAM_BOT_TOKEN=여기에_봇토큰_입력
TELEGRAM_CHAT_ID=여기에_채팅ID_입력
ADMIN_IDS=  # 추가 관리자 chat_id (콤마 구분, 선택). 예) ADMIN_IDS=28033830,987654321

# Anthropic API 키
ANTHROPIC_API_KEY=sk-ant-...

# 확인 주기 (분 단위, 기본값: 60)
CHECK_INTERVAL_MINUTES=60

# 날씨/미세먼지 API 키 (공공데이터포털 발급)
WEATHER_API_KEY=여기에_API키_입력
